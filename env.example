# ============================================
# 鏅鸿储Agent - 閰嶇疆妯℃澘
# ============================================
# 浣跨敤鏂瑰紡锛?# 1. 澶嶅埗 backend/src/main/resources/application-local.yml
#    鍒板悓鐩綍锛堣繖涓枃浠跺凡鍦?.gitignore 涓級
# 2. 濉叆鐪熷疄鐨勫瘑閽ュ拰瀵嗙爜
# 3. 鐩存帴杩愯 mvn spring-boot:run 鍗冲彲
# ============================================

# MySQL 鏁版嵁搴撳瘑鐮?spring:
  datasource:
    password: 浣犵殑鏁版嵁搴撳瘑鐮?
# JWT 鍔犲瘑瀵嗛挜锛堝缓璁娇鐢ㄩ殢鏈洪暱瀛楃涓诧級
jwt:
  secret: 浣犵殑JWT瀵嗛挜

# DashScope 閫氫箟鍗冮棶 API Key
# 鑾峰彇鍦板潃锛歨ttps://dashscope.aliyuncs.com
langchain4j:
  dashscope:
    api-key: ${DASHSCOPE_API_KEY}

# Tavily 鑱旂綉鎼滅储 API Key锛堝彲閫夛級
# 鑾峰彇鍦板潃锛歨ttps://app.tavily.com
search:
  api-key: ${TAVILY_API_KEY}
