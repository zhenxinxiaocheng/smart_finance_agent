# ============================================
# 智财Agent - 配置模板
# ============================================
# 使用方式：
# 1. 复制 backend/src/main/resources/application-local.yml
#    到同目录（这个文件已在 .gitignore 中）
# 2. 填入真实的密钥和密码
# 3. 直接运行 mvn spring-boot:run 即可
# ============================================

# MySQL 数据库密码
spring:
  datasource:
    password: 你的数据库密码

# JWT 加密密钥（建议使用随机长字符串）
jwt:
  secret: 你的JWT密钥

# DashScope 通义千问 API Key
# 获取地址：https://dashscope.aliyuncs.com
langchain4j:
  dashscope:
    api-key: sk-你的API密钥

# Tavily 联网搜索 API Key（可选）
# 获取地址：https://app.tavily.com
search:
  api-key: tvly-你的API密钥
